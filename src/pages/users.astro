---
import Layout from '../layouts/Layout.astro';
import UsersTable from '../components/UsersTable.jsx';
---

<Layout>
  <header class="users-header">
    <div class="header-brand">
      <img class="logo" src="/Lboard_Logo.png" alt="LBoard Logo" />
      <div class="brand-text">
        <h1>Cluster Command</h1>
        <p class="brand-subtitle">Optimize jobs. Save GPU hours. Move the snail.</p>
      </div>
    </div>
    <nav class="header-nav">
      <a href="/#game-section">Game</a>
      <a class="leader-link" href="/#leader-section">Leader Board</a>
      <a class="loser-link" href="/#loser-section">Loser Board</a>
      <a href="/users">Users</a>
    </nav>
  </header>

  <main class="users-main">
    <section class="users-section">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">Roster Index</p>
          <h2>All Users</h2>
          <p class="section-description">Search and filter all users by efficiency, GPU hours, and more.</p>
        </div>
        <span class="live-badge gold">Live Roster</span>
      </div>
      <UsersTable client:load />
    </section>
  </main>
</Layout>

<style>
  .users-header {
    display: grid;
    grid-template-columns: 1fr;
    row-gap: 0.8rem;
    align-items: center;
    padding: 0.5rem 1rem;
    color: #fff;
    background: #061318;
    border-bottom: 1px solid #53d5fd;
    box-shadow: 0 0 20px rgba(83, 213, 253, 0.5);
    min-height: 64px;
    backdrop-filter: blur(10px);
    box-sizing: border-box;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-self: start;
  }

  .header-brand h1 {
    margin: 0;
    font-family: 'Orbitron', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #53d5fd;
    text-shadow:
      0 0 8px #53d5fd,
      0 0 20px #53d5fd,
      0 0 40px rgba(83,213,253,.5);
    text-transform: uppercase;
  }

  .logo {
    width: 60px;
    height: 60px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .brand-subtitle {
    margin: 0;
    color: #d5ad4d;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .header-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3.5rem;
    justify-self: center;
  }

  .header-nav a {
    display: inline-block;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: white;
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 0.4rem 0.7rem;
    border-radius: 6px;
  }

  .header-nav a:hover {
    background: rgba(83, 213, 253, 0.15);
    color: #b6eeff;
    box-shadow: 0 0 12px rgba(83, 213, 253, 0.35);
    transform: translateY(-2px);
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
  }

  .header-nav .leader-link {
    color: white;
  }

  .header-nav .leader-link:hover {
    background: rgba(83, 213, 253, 0.15);
    color: white;
  }

  .header-nav .loser-link {
    color: white;
  }

  .header-nav .loser-link:hover {
    background: rgba(213, 173, 77, 0.15);
    color: white;
  }

  .users-main {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top, rgba(83, 213, 253, 0.12), transparent 35%),
      radial-gradient(circle at bottom right, rgba(213, 173, 77, 0.1), transparent 30%),
      #111;
  }

  .users-section {
    padding: 3rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid rgba(83, 213, 253, 0.28);
    border-radius: 24px;
    background: #061318;
    box-shadow: 0 0 24px rgba(83, 213, 253, 0.12);
  }

  .section-eyebrow {
    margin: 0 0 0.6rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #d5ad4d;
  }

  .section-header h2 {
    margin: 0 0 0.5rem;
    font-size: 2rem;
    font-family: 'Orbitron', sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #53d5fd;
    text-shadow:
      0 0 8px rgba(83, 213, 253, 0.6),
      0 0 18px rgba(83, 213, 253, 0.18);
  }

  .section-description {
    margin: 0;
    color: #cbd5e1;
    font-size: 1rem;
    max-width: 40rem;
    line-height: 1.7;
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.9rem;
    border: 1px solid #53d5fd;
    color: #53d5fd;
    border-radius: 999px;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    box-shadow: 0 0 12px rgba(83, 213, 253, 0.25);
    white-space: nowrap;
  }

  .live-badge::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 10px currentColor;
  }

  .live-badge.gold {
    border-color: #d5ad4d;
    color: #d5ad4d;
    box-shadow: 0 0 12px rgba(213, 173, 77, 0.25);
  }

  @media (max-width: 768px) {
    .header-nav {
      gap: 1.5rem;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .section-header h2 {
      font-size: 1.5rem;
    }
  }
</style>
