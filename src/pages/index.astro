---
import GamePlaceholder from "../components/GamePlaceholder.jsx";
import LeaderBoard from "../components/LeaderBoard.astro";
import LoserBoard from "../components/LoserBoard.astro";
---
<header class="header">
	<div class="header-brand">
		<img class="logo" src="/Lboard_Logo.png" alt="LBoard Logo" />
		<div class="brand-text">
			<h1>Cluzster Command</h1>
			<p class="brand-subtitle">Optimize jobs. Save GPU hours. Move the snail.</p>
		</div>
	</div>
	<nav class="header-nav">
		<a href="#game-section">Game</a>
		<a class="leader-link" href="#leader-section">Leader Board</a>
		<a class="loser-link" href="#loser-section">Loser Board</a>
		<a href="/users">Users</a>
	</nav>
</header>

<main>
  <section id="game-section" class="game-section">
    <div class="game-wrapper">
      <div class="status-banner status-banner-compact">
        <span class="status-dot"></span>
        <span>Cluster Utilization: Low</span>
      </div>

      <div class="hero-card">
        <p class="hero-eyebrow">Cluster Command</p>
        <p class="hero-copy">Assign jobs to CPUs and GPUs. The better your efficiency, the faster the snail moves.</p>
      </div>

      <div class="game-placeholder-card">
        <GamePlaceholder client:load />
      </div>
    </div>
  </section>

  <section id="leader-section" class="leader-section">
    <div class="dashboard-card">
      <LeaderBoard />
      <h1>Leader Board</h1>
      <table>
		<thead>
			<tr>
				<th></th>
				<th>
					<span class="table-label">
						<span class="table-icon-bg">
							<img class="table-icon" src="/Name.png" alt="Name icon" />
						</span>
						Name
					</span>
				</th>
				<th>
					<span class="table-label">
						<span class="table-icon-bg">
							<img class="table-icon" src="/GPU.png" alt="GPU icon" />
						</span>
						Efficiency
					</span>
				</th>
				<th>
					<span class="table-label">
						<span class="table-icon-bg">
							<img class="table-icon" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2024%2024'%3E%3Cpolygon%20points='5,16%2012,8%2019,16'%20fill='%2310b981'/%3E%3C/svg%3E" alt="Up arrow icon" />
						</span>
						GPU Hours Gained
					</span>
				</th>
			</tr>
		</thead>

		<tbody>
			<tr class="leader-first">
				<td>1</td>
				<td>Hiii Florine</td>
				<td>95</td>
				<td>95</td>
			</tr>
			<tr class="leader-second">
				<td>2</td>
				<td>Best Volleybal Player</td>
				<td>88</td>
				<td>95</td>
			</tr>
			<tr class="leader-third">
				<td>3</td>
				<td>tallest Flo</td>
				<td>92</td>
				<td>92</td>
			</tr>
			<tr>
				<td>4</td>
				<td>Quantum Quinton</td>
				<td>90</td>
				<td>88</td>
			</tr>
			<tr>
				<td>5</td>
