</main>

<style>
  main {
    margin: 0;
  }

  section {
    min-height: 100vh;
    padding: 1rem 2rem;
  }

  .game-section {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    background: #111;
	color: #fff;
	padding-top:0;
  }

  .leader-section {
    background: #f4f4f4;
	color: #333;
  }

  .loser-section {
    background: #e5e5e5;
	color: #333;
  }

  header {
	display: grid;
	grid-template-columns: 1fr;
	row-gap: 0.8rem;
	align-items: center;
	padding: 0.5rem 1rem;
	color: #fff;
	background: rgba(34, 34, 34, 0.96);
	min-height: 64px;
	backdrop-filter: blur(10px);
	box-sizing: border-box;
  }

  main {
    margin: 0;
  }

  .header-brand {
	display: flex;
	align-items: center;
	gap: 1rem;
	justify-self: start;
  }

  .header-brand h1 {
	margin: 0;
  }

	.logo {
		width: 60px; /* smaller logo to reduce header height */
		height: 60px;
		object-fit: contain;
		flex-shrink: 0;
	}

  .leader-section h1,
  .loser-section h1 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

	/* header nav (moved into header) */
	.header-nav {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 3.5rem; /* increased spacing between links */
		justify-self: center;
	}

	nav a{
		display: inline-block;
		color: white;
		text-decoration: none;
		transition: all 0.2s ease;
		padding: 0.4rem 0.7rem; /* smaller padding to keep header compact */
		border-radius: 6px;
	}

  nav a:hover {
	background: #717171;
	transform: translateY(-2px);
	padding: 0.75rem 1.25rem;
	border-radius: 8px;

  }

  nav a.leader-link:hover {
	background: rgba(22, 163, 74, 0.2);
	transform: translateY(-2px);
	border-radius: 8px;
	color: white;
  }

  nav a.loser-link:hover {
	background: rgba(220, 38, 38, 0.2);
	transform: translateY(-2px);
	border-radius: 8px;
	color: white;
  }

  .game-wrapper {
	display: flex;
	flex-direction: column;
	gap: 1.25rem;
	max-width: 950px;
	margin: 0 auto;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .brand-subtitle {
    margin: 0;
    color: #a7f3d0;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .hero-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 24px;
    padding: 1.5rem;
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.15);
  }

  .hero-eyebrow {
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: #86efac;
  }

  .hero-copy {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #e5e7eb;
  }

  .game-placeholder-card {
    padding: 1.25rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

	.status-banner {
	display: flex;
	align-items: center;
	gap: 0.5rem;

	padding: 0.5rem 0.85rem;

	background: rgba(34, 197, 94, 0.14);
	border: 1px solid rgba(34, 197, 94, 0.25);
	border-radius: 12px;
	box-shadow: 0 0 18px rgba(34, 197, 94, 0.12);
	max-width: 420px;
  }

	.status-dot {
	width: 8px;
	height: 8px;

	background: #22c55e;
	border-radius: 50%;
	box-shadow: 0 0 8px rgba(34, 197, 94, 0.7);
  }

  .dashboard-card {
    margin: 2rem auto;
    padding: 1.5rem;
    background: white;
    border-radius: 24px;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    max-width: 960px;
  }

  .dashboard-card h1 {
    margin: 0 0 1rem;
  }

  .leader-section .dashboard-card {
    background: #f6fffa;
  }

  .loser-section .dashboard-card {
    background: #fff1f2;
  }

  .leader-section table th,
  .leader-section table thead th {
    background: #16a34a !important;
    color: white !important;
  }

  .loser-section table th,
  .loser-section table thead th {
    background: #dc2626 !important;
    color: white !important;
  }

  /*table styles*/
  table {
	width: 100%;
	max-width: 900px;
	margin: 2rem auto;
	border-collapse: collapse;
	background: white;
	border-radius: 16px;
	overflow: hidden;
	margin: 2rem auto;
  }

	th,
	td {
	padding: 1rem 1.25rem;
	text-align:center;
	border-bottom: 1px solid #ddd;
  }

	th {
	background: #222;
	color: white;
	font-weight: 700;
  }

  .table-label {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	white-space: nowrap;
  }

  .table-icon-bg {
	width: 36px;
	height: 36px;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	background: white;
	border-radius: 50%;
	overflow: hidden;
	box-shadow: 0 0 0 1px rgba(255,255,255,0.1);
  }

  .table-icon {
	width: 100%;
	height: 100%;
	display: block;
	object-fit: cover;
  }

  .leader-first,
  .leader-second,
  .leader-third {
    background: transparent;
    color: inherit;
    box-shadow: none;
  }

  .leader-first td:first-child::before {
    content: '🏆';
    margin-right: 0.35rem;
  }
  .leader-second td:first-child::before {
    content: '🥈';
    margin-right: 0.35rem;
  }
  .leader-third td:first-child::before {
    content: '🥉';
    margin-right: 0.35rem;
  }
  .leader-first td:first-child,
  .leader-second td:first-child,
  .leader-third td:first-child {
    font-weight: 700;
    position: relative;
  }

  .leader-first td:first-child {
    overflow: visible;
  }

  .leader-first td:first-child::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0;
    height: 0;
    opacity: 0;
    box-shadow:
      -10px -10px 0 0 #facc15,
      10px -12px 0 0 #f97316,
      -8px 8px 0 0 #fde68a,
      12px 6px 0 0 #ef4444,
      0px 12px 0 0 #a855f7;
    transform: translate(-50%, -50%) scale(0.5);
    pointer-events: none;
  }

  .leader-first:hover td:first-child::after {
    opacity: 1;
    animation: confetti-burst 0.65s ease-out forwards;
  }

  .loser-worst td:first-child::before {
    content: '⚠️';
    margin-right: 0.35rem;
  }
  .loser-second-worst td:first-child::before {
    content: '🐌';
    margin-right: 0.35rem;
  }
  .loser-third-worst td:first-child::before {
    content: '🐌';
    margin-right: 0.35rem;
  }
  .loser-worst td:first-child,
  .loser-second-worst td:first-child,
  .loser-third-worst td:first-child {
    font-weight: 700;
  }

  @keyframes confetti-burst {
    0% {
      opacity: 0;
      transform: translate(0, 0) scale(0.75);
    }
    40% {
      opacity: 1;
      transform: translate(8px, -8px) scale(1);
    }
    80% {
      transform: translate(14px, -18px) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(18px, -28px) scale(0.8);
    }
  }

  .loser-worst,
  .loser-second-worst,
  .loser-third-worst {
    background: transparent;
    box-shadow: none;
  }

  tbody tr {
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .leader-section tbody tr:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(34, 34, 34, 0.08);
  }

  .loser-section tbody tr:hover {
    transform: translateY(0);
    background-color: rgba(0, 0, 0, 0.04);
  }

  .loser-section tbody tr:hover {
    animation: loser-shake 0.35s ease-in-out;
  }

  @keyframes loser-shake {
    0% { transform: translateX(0); }
    25% { transform: translateX(-2px); }
    50% { transform: translateX(2px); }
    75% { transform: translateX(-1px); }
    100% { transform: translateX(0); }
  }

	tbody tr:last-child td {
	border-bottom: none;
  }
</style>
