---
import Layout from "../layouts/Layout.astro";
import GameApp from "../game/src/App.tsx";
---

<Layout>
  <main class="game-page">
    <section class="game-section" aria-label="Cluster Command game">
      <GameApp client:only="react" embedded />
    </section>
  </main>
</Layout>

<style>
  .game-page {
    min-height: calc(100vh - 70px);
    background: #02020a;
  }

  .game-section {
    min-height: calc(100vh - 70px);
    display: block;
    background: #02020a;
  }
</style>