---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
---
<Layout>
<SiteHeader context="home" />

<main>

  <!-- HERO -->
  <section id="hero" class="hero">

    <!-- LEFT -->
    <div class="hero-left">
      <div class="hero-prompt">
		$ cluster --status <span class="cursor">▮</span>
	</div>
	  <h1 class="hero-title"><span>Cluster Analytics</span><br>  <span class="platform">Platform</span></h1>
      <p class="hero-tagline">
		Real time cluster analytics for researchers who care about performance. Command the cluster. 
		Save GPU hours. Move Slurm forward.
	  </p>
      <div class="hero-status-panel">
        <div class="hero-status-top">
          <span class="hero-live-pill">
            <span class="hero-live-dot"></span>
            Live Cluster Status
          </span>
        </div>
        <div class="hero-status-grid">
          <div class="hero-status-card load">
            <span class="status-label">Load</span>
            <strong>Low Load</strong>
          </div>
        </div>
      </div>
      <a href="/game" class="cta-btn">▶ PLAY CLUSTER _cmd</a>
    </div>

    <!-- RIGHT: Slurm-o dashboard unchanged -->
    <div class="hero-right">
      <div class="util-panel blazing">
        <div class="util-header">
          slurm-o status
        </div>
        <img class="snail-img cruising" src="/snail.png" alt="slurm-o" />
		<div class="snail-speed">  
			<span></span>  
			<span></span>  
			<span></span>
		</div>
        <div class="util-status">BLAZING</div>
        <div class="util-bar">
          <div class="util-fill" data-width="90%"></div>
        </div>
        <div class="util-labels">
          <span>CRAWLING</span>
          <span>68%</span>
          <span>BLAZING</span>
        </div>
      </div>
    </div>
  </section>

  <!-- LEADER BOARD -->
  <section id="leader-section" class="leader-section">
    <div class="dashboard-card">
      <div class="board-header">
        <div>
          <h1>Leader Board</h1>
          <p class="board-subtitle">TOP 10 COMMANDERS</p>
        </div>
      </div>
      <table>
        <thead>
          <tr>
            <th></th>
            <th><span class="table-label"><span class="table-icon-bg"><img class="table-icon" src="/Name.png" alt="Name icon" /></span>Name</span></th>
            <th><span class="table-label"><span class="table-icon-bg"><img class="table-icon" src="/GPU.png" alt="GPU icon" /></span>Efficiency</span></th>
            <th><span class="table-label"><span class="table-icon-bg"><img class="table-icon" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2024%2024'%3E%3Cpolygon%20points='5,16%2012,8%2019,16'%20fill='%2310b981'/%3E%3C/svg%3E" alt="Up arrow" /></span>GPU Hours Gained</span></th>
            <th>SCORE</th>
          </tr>
        </thead>
        <tbody>
          <tr class="leader-first"><td>1</td><td>Florine</td><td>95</td><td><div class="gpu-cell"><span>95hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="95%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr class="leader-second"><td>2</td><td>Best Volleybal Player</td><td>88</td><td><div class="gpu-cell"><span>90hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="90%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr class="leader-third"><td>3</td><td>tallest Flo</td><td>92</td><td><div class="gpu-cell"><span>85hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="85%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>4</td><td>Quantum Quinton</td><td>90</td><td><div class="gpu-cell"><span>80hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="80%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>5</td><td>Data Dana</td><td>88</td><td><div class="gpu-cell"><span>75hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="75%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>6</td><td>Algorithm Aiden</td><td>86</td><td><div class="gpu-cell"><span>70hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="70%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>7</td><td>Pipeline Priya</td><td>84</td><td><div class="gpu-cell"><span>68hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="68%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>8</td><td>Kernel Ken</td><td>82</td><td><div class="gpu-cell"><span>65hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="65%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>9</td><td>Tensor Tessa</td><td>80</td><td><div class="gpu-cell"><span>60hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="60%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>10</td><td>Vector Vance</td><td>78</td><td><div class="gpu-cell"><span>55hrs</span><div class="gpu-bar"><div class="gpu-fill" data-width="55%" style="width:0"></div></div></div></td><td>500</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- LOSER BOARD -->
  <section id="loser-section" class="loser-section">
    <div class="dashboard-card">
      <div class="board-header">
        <div>
          <h1>Loser Board</h1>
          <p class="board-subtitle">BOTTOM 10 COMMANDERS</p>
        </div>
      </div>
      <table>
        <thead>
          <tr>
            <th></th>
            <th><span class="table-label"><span class="table-icon-bg"><img class="table-icon" src="/Name.png" alt="Name icon" /></span>Name</span></th>
            <th><span class="table-label"><span class="table-icon-bg"><img class="table-icon" src="/GPU.png" alt="GPU icon" /></span>Efficiency</span></th>
            <th><span class="table-label"><span class="table-icon-bg"><img class="table-icon" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2024%2024'%3E%3Cpolygon%20points='12,18%205,8%2019,8'%20fill='%23ef4444'/%3E%3C/svg%3E" alt="Down arrow" /></span>GPU Hours Gained</span></th>
            <th>SCORE</th>
          </tr>
        </thead>
        <tbody>
          <tr class="loser-worst"><td>1</td><td>Aaron</td><td>95</td><td><div class="gpu-cell"><span>50hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="50%" style="width:0"></div></div></div></td><td>5000</td></tr>
          <tr class="loser-second-worst"><td>2</td><td>Ian</td><td>88</td><td><div class="gpu-cell"><span>45hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="45%" style="width:0"></div></div></div></td><td>4200</td></tr>
          <tr class="loser-third-worst"><td>3</td><td>Theo</td><td>92</td><td><div class="gpu-cell"><span>37hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="37%" style="width:0"></div></div></div></td><td>3900</td></tr>
          <tr><td>4</td><td>Laggy Lana</td><td>70</td><td><div class="gpu-cell"><span>30hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="30%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>5</td><td>Crash Carl</td><td>68</td><td><div class="gpu-cell"><span>35hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="35%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>6</td><td>Stuck Steve</td><td>66</td><td><div class="gpu-cell"><span>30hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="30%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>7</td><td>Frozen Fran</td><td>64</td><td><div class="gpu-cell"><span>20hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="20%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>8</td><td>Snail Nate</td><td>62</td><td><div class="gpu-cell"><span>10hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="10%" style="width:0"></div></div></div></td><td>58</td></tr>
          <tr><td>9</td><td>Buffer Beth</td><td>60</td><td><div class="gpu-cell"><span>5hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="5%" style="width:0"></div></div></div></td><td>500</td></tr>
          <tr><td>10</td><td>Timeout Tim</td><td>58</td><td><div class="gpu-cell"><span>3hrs</span><div class="gpu-bar"><div class="gpu-fill gold" data-width="3%" style="width:0"></div></div></div></td><td>500</td></tr>
        </tbody>
      </table>
    </div>
  </section>

	<script>
	document.addEventListener("DOMContentLoaded", () => {

	const utilBar = document.querySelector(".util-fill:not(.gpu-fill)");
	const snail = document.querySelector(".snail-img");
	const speed = document.querySelector(".snail-speed");
	const status = document.querySelector(".util-status");

	if (utilBar && snail && status) {
		const percent = parseInt(utilBar.dataset.width);

		setTimeout(() => {
		utilBar.style.width = utilBar.dataset.width;
		}, 300);

		if (percent < 40) {
		snail.className = "snail-img crawling";
		status.textContent = "CRAWLING";
		speed.classList.remove("active");

		} else if (percent < 75) {
		snail.className = "snail-img cruising";
		status.textContent = "CRUISING";
		speed.classList.remove("active");

		} else {
		snail.className = "snail-img blazing";
		status.textContent = "BLAZING";
		speed.classList.add("active");
		}
	}

	// leaderboard animation
	const observer = new IntersectionObserver(entries => {
		entries.forEach(entry => {
		if (!entry.isIntersecting) return;
		entry.target.querySelectorAll(".gpu-fill").forEach(bar => {
			setTimeout(() => {
			bar.style.width = bar.dataset.width;
			}, 150);
		});
		});
	});

	document.querySelectorAll(".dashboard-card").forEach(card => {
		observer.observe(card);
	});

	});
	</script>

</main>
</Layout>

<style>
  :root {
    --gpu-primary: #53d5fd;
    --gpu-glow: #b6eeff;
    --cpu-primary: #d5ad4d;
    --cpu-glow: #ffebaf;
  }

  main { margin: 0; }
  /*Cursor*/
  .cursor {
  display: inline-block;
  margin-left: 4px;
  animation: blink 1s steps(2, start) infinite;
}

@keyframes blink {
  to { visibility: hidden; }
}

  /* BASE */
.snail-img {
  height: auto;
  width: 200px;
  margin: 1.2rem auto;
  display: block;
  filter: drop-shadow(0 0 10px rgba(213, 173, 77, 0.14));
}
 /**/

/* STATES */
.snail-img.crawling {
  animation: crawl 4s ease-in-out infinite;
}

.snail-img.cruising {
  animation: float 2.5s ease-in-out infinite;
}

.snail-img.blazing {
  animation: bounce 0.6s ease-in-out infinite;
}

/* KEYFRAMES */
@keyframes crawl {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-2px); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

/* SPEED */
.snail-wrap {
  position: relative;
  display: flex;
  justify-content: center;
}

.snail-speed {
  position: absolute;
  left: -20px;
  top: 50%;
  transform: translateY(-50%);
  width: 100px;
  opacity: 0;
}

.snail-speed span {
  display: block;
  height: 2px;
  margin: 6px 0;
  background: linear-gradient(90deg, transparent, #53d5fd, transparent);
  animation: speed 0.4s linear infinite;
}

.snail-speed span:nth-child(2) {
  animation-delay: 0.1s;
}

.snail-speed span:nth-child(3) {
  animation-delay: 0.2s;
}

@keyframes speed {
  from { transform: translateX(-20px); opacity: 0; }
  to   { transform: translateX(20px); opacity: 1; }
}

.snail-speed.active {
  opacity: 1;
}


 

  .terminal {
	opacity: 0.8
  }

  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 800;
    font-size: clamp(2.65rem, 5vw, 4.2rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: #d8d8d8;
    margin: 0.15rem 0 0.25rem 0;

  }

  .hero-title span:first-child {
    color: #d8d8d8;
  }

  .hero-title .platform {
    font-size: 0.82em;
	font-weight: 700;
    color: #676969;
	display: block;
	margin-top: 2px;
  }


  .hero-description{
	color: #5c7c7c;
	margin-top: 0.2rem;
  }
  /* ── HERO ── */
.hero {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;

  min-height: calc(100vh - 70px);
  padding: 3rem 4rem 0;
  gap: 2rem 3rem;

  background:
    linear-gradient(
      180deg,
      rgba(83, 213, 253, 0.18) 0%,
      rgba(83, 213, 253, 0.08) 15%,
      rgba(83, 213, 253, 0.02) 25%,
      transparent 45%
    ),
    #0a0e14;

  overflow: hidden;
}

.hero > * {
  position: relative;
  z-index: 1;
}


  /* left */
  .hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.7rem;   /* ✅ tight F1 spacing */
}

  .hero-prompt {
    font-size: 0.85rem;
    color: #10b981;
    letter-spacing: 0.1em;
    font-family: 'Courier New', monospace;
    position: relative;
    z-index: 2;
	margin-bottom: 0.1rem;
  }
  .hero-tagline {
    font-size: 1.15rem;
    line-height: 1.6;
    color: #94a3b8;
    margin-top: 0.35rem;
  }
  .hero-status-panel {
    width: min(100%, 30rem);
    padding: 1rem 1.1rem;
    border: 1px solid rgba(83,213,253,0.2);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(6,19,24,0.96), rgba(6,19,24,0.7));
    box-shadow: 0 18px 40px rgba(0,0,0,0.24), 0 0 18px rgba(83,213,253,0.08);
    backdrop-filter: blur(10px);
  }
  .hero-status-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }
  .hero-live-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(83,213,253,0.28);
    background: rgba(83,213,253,0.08);
    color: #b6eeff;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .hero-live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 12px rgba(16,185,129,0.9);
    animation: pulse 1.5s infinite;
  }
  .hero-status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.8rem;
  }
  .hero-status-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.95rem 1rem;
    border-radius: 14px;
    border: 1px solid transparent;
    background: rgba(255,255,255,0.03);
  }
  .hero-status-card .status-label {
    color: #7a8ba3;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-family: 'Orbitron', sans-serif;
  }
  .hero-status-card strong {
    font-family: 'Orbitron', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .hero-status-card.online {
    border-color: rgba(16,185,129,0.28);
    background: linear-gradient(180deg, rgba(16,185,129,0.14), rgba(16,185,129,0.04));
  }
  .hero-status-card.online strong {
    color: #78f0c3;
    text-shadow: 0 0 14px rgba(16,185,129,0.22);
  }
  .hero-status-card.load {
    border-color: rgba(213,173,77,0.28);
    background: linear-gradient(180deg, rgba(213,173,77,0.14), rgba(213,173,77,0.04));
  }
  .hero-status-card.load strong {
    color: #ffdf8b;
    text-shadow: 0 0 14px rgba(213,173,77,0.22);
  }
  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    background: #53d5fd;
    color: #061318;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    border-radius: 8px;
    text-decoration: none;
    width: fit-content;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .cta-btn:hover { box-shadow: 0 0 28px rgba(83,213,253,0.45); transform: translateY(-2px); }

  /* right: slurm-o — unchanged */
  .hero-right { display: flex; justify-content: center; }
  .util-panel {
    padding: 2rem 3rem;
    background: linear-gradient(180deg, rgba(8, 12, 19, 0.9), rgba(8, 12, 19, 0.48));
    border: 1px solid rgba(83, 213, 253, 0.14);
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
    border-radius: 28px;
    backdrop-filter: blur(12px);
    text-align: left;
    width: 100%;
    max-width: 380px;
  }
  .util-panel.blazing {
    border-color: rgba(213, 173, 77, 0.42);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.32), 0 0 18px rgba(213, 173, 77, 0.1);
  }
  .util-header {
    color: #53d5fd;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    text-transform: uppercase;
    font-family: 'Orbitron', sans-serif;
  }

  .util-status {
    color: #d5ad4d;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
    text-align: center;
    font-size: 0.88rem;
  }
  .util-bar {
    height: 8px;
    background: rgba(255,255,255,.08);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  .util-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: linear-gradient(90deg,#53d5fd,#d5ad4d);
    transition: width 1.8s ease;
  }
  .util-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: #7a8ba3;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 2.5rem 1.5rem 1rem;
    }

    .hero::before {
      background:
        linear-gradient(180deg, rgba(126, 0, 10, 0.22) 0%, rgba(54, 0, 12, 0.1) 20%, rgba(10, 14, 20, 0) 38%),
        radial-gradient(circle at 24% 8%, rgba(255, 30, 30, 0.12) 0%, rgba(255, 30, 30, 0.03) 18%, rgba(10, 14, 20, 0) 34%);
    }

    .hero-right {
      justify-content: center;
    }

    .util-panel {
      padding: 1.75rem 1.5rem;
    }

    .hero-status-top {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .hero-status-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── SECTIONS ── */
  section { padding: 1rem 2rem; }
  .leader-section { background: #111; color: #b6eeff; }
  .loser-section  { background: #111; color: #ffebaf; }

  /* ── BOARDS ── */
  .board-subtitle {
    margin: 0 0 1rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #7a8ba3;
  }
  .board-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .board-header h1 {
    margin: 0 0 0.25rem;
    font-family: 'Orbitron', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .dashboard-card {
    backdrop-filter: blur(8px);
    margin: 2rem auto;
    padding: 1.5rem;
    background: #061318;
    border-radius: 24px;
    max-width: 960px;
  }
  .leader-section .dashboard-card {
    border: 1px solid #53d5fd;
    box-shadow: 0 0 20px rgba(83,213,253,.15);
  }
  .loser-section .dashboard-card {
    background: #111;
    border: 1px solid #d5ad4d;
  }

  /* ── TABLE ── */
  table {
    width: 100%;
    max-width: 900px;
    margin: 2rem auto;
    border-collapse: collapse;
    background: #061318;
    color: #b6eeff;
    border-radius: 16px;
    overflow: hidden;
  }
  th, td {
    padding: 1rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid rgba(83,213,253,0.12);
  }
  th { background: #222; color: white; font-weight: 700; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr { transition: transform 0.2s ease, background-color 0.2s ease; }

  .leader-section table th { background: rgba(83,213,253,0.08) !important; color: #53d5fd !important; border-bottom: 1px solid rgba(83,213,253,0.12); }
  .loser-section  table th { background: #432d00 !important; color: #d5ad4d !important; border-bottom: 1px solid rgba(213,173,77,0.12); }
  .leader-section tbody tr:hover { transform: translateY(-3px); }
  .loser-section  tbody tr:hover { animation: loser-shake 0.35s ease-in-out; }

  .table-label { display: inline-flex; align-items: center; gap: 0.5rem; white-space: nowrap; }
  .table-icon-bg {
    width: 36px; height: 36px;
