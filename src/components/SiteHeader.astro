---
const { context = "home" } = Astro.props;
const onHome = context === "home";
const baseUrl = import.meta.env.BASE_URL || "/";

const heroHref = onHome ? "#hero" : `${baseUrl}#hero`;
const leaderHref = onHome ? "#leader-section" : `${baseUrl}#leader-section`;
const loserHref = onHome ? "#loser-section" : `${baseUrl}#loser-section`;
const gameHref = `${baseUrl}game`;
const usersHref = `${baseUrl}users`;
---

<header class="site-header">
  <a class="header-brand" href={heroHref} aria-label="Cluster_cmd (Back to hero)">
    <img class="logo" src="/Lboard_Logo.png" alt="LBoard Logo" />
    <div class="brand-text">
      <h1>
        <span class="cluster-text">Cluster</span>
        <span class="cmd-text">_cmd</span>
      </h1>
      <p class="brand-subtitle">Optimize jobs. Save GPU hours. Move the snail.</p>
    </div>
  </a>
  <nav class="header-nav" aria-label="Primary">




    <a href={gameHref}>GAME</a>
    <a class="leader-link" href={leaderHref}>LEADER BOARD</a>
    <a class="loser-link" href={loserHref}>LOSER BOARD</a>
    <a href={usersHref}>USERS</a>
  </nav>
</header>

