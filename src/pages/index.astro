  <script>
  document.addEventListener("DOMContentLoaded", () => {
	const observer = new IntersectionObserver(entries => {
		entries.forEach(entry => {
			if (!entry.isIntersecting) return;

			entry.target.querySelectorAll(".gpu-fill").forEach(bar => {
				setTimeout(() => {
					bar.style.width = bar.dataset.width;
				}, 150);
			});
		});
  });

	document.querySelectorAll(".dashboard-card").forEach(card => {
		observer.observe(card);
	});
  });
  </script>
</main>
 </Layout>

<style>
  main {
    margin: 0;
  }

  section {
    min-height: 100vh;
    padding: 1rem 2rem;
  }

  :root {
  --bg: #111;

  --gpu-primary: #53d5fd;
  --gpu-glow: #b6eeff;

  --cpu-primary: #d5ad4d;
  --cpu-glow: #ffebaf;
  }

  .game-section {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    background: #111;
	color: #fff;
	padding-top:0;
  }

  .leader-section {
    background: #111;
	color: #b6eeff;
  }

  .loser-section {
    background: #111;
	color: #ffebaf;
  }

  header {
	display: grid;
	grid-template-columns: 1fr;
	row-gap: 0.8rem;
	align-items: center;
	padding: 0.5rem 1rem;
	color: #fff;
	background: #061318;
	border-bottom: 1px solid #53d5fd;
	box-shadow: 0 0 20px rgba(83, 213, 253, 0.5);
	min-height: 64px;
	backdrop-filter: blur(10px);
	box-sizing: border-box;
  }

  .board-subtitle {
	margin: 0 0 1rem;
	font-family: 'Orbitron', sans-serif;
	font-size: 0.75rem;
	letter-spacing: 0.25em;
	text-transform: uppercase;
	color: #7a8ba3;
  }

  .board-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
  }

  .live-badge {
	padding: 0.35rem 0.8rem;
	border: 1px solid #53d5fd;
	color: #53d5fd;
	border-radius: 999px;
	font-size: 0.75rem;
	letter-spacing: 0.15em;
	box-shadow: 0 0 12px rgba(83,213,253,.25);
  }

  .live-badge.gold {
	border-color: #d5ad4d;
	color: #d5ad4d;
	box-shadow: 0 0 12px rgba(213,173,77,.25);
  }

  .live-badge::before {
	content: "";
	width: 8px;
	height: 8px;
	background: currentColor;
	border-radius: 50%;
	display: inline-block;
	margin-right: 6px;
	animation: pulse 1.5s infinite;
  }

  .gpu-fill {
	height: 100%;
	width: 0;
	background: linear-gradient(
		90deg,
		#53d5fd,
		#b6eeff
	);
	border-radius: 999px;
	box-shadow: 0 0 12px #53d5fd;
	transition: width 1.8s ease-out;
  }


  .gpu-fill.gold {
	background: linear-gradient(
		90deg,
		#d5ad4d,
		#ffebaf
	);
	box-shadow: 0 0 12px #d5ad4d;
  }

  .gpu-fill {
	position: relative;
	overflow: hidden;
  }

  .gpu-fill::after {
	content: "";
	position: absolute;
	top: 0;
	left: -100%;
	width: 100%;
	height: 100%;
	background: rgba(255,255,255,.35);
	animation: sweep 2.5s infinite;
  }

  @keyframes sweep {
	0% { left: -100%; }
	100% { left: 100%; }
  }

  @keyframes pulse {
	0% { opacity: .4; }
	50% { opacity: 1; }
	100% { opacity: .4; }
  }

  main {
    margin: 0;
  }

  .header-brand {
	display: flex;
	align-items: center;
	gap: 1rem;
	justify-self: start;
  }

  .header-brand h1 {
	margin: 0;
	font-family: 'Orbitron', sans-serif;
	font-size: 2rem;
	font-weight: 800;
	letter-spacing: 0.12em;
	color: #53d5fd;
	text-shadow:
		0 0 8px #53d5fd,
		0 0 20px #53d5fd,
		0 0 40px rgba(83,213,253,.5);
	text-transform: uppercase;
  }

  .board-header h1,
  .live-badge,
  .header-nav a,
  .hero-eyebrow {
	font-family: 'Orbitron', sans-serif;
  }

  .board-header h1 {
	text-transform: uppercase;
	letter-spacing: 0.08em;
  }

  .header-nav a {
	display: inline-block;
	color: white;
	text-decoration: none;
	transition: all 0.2s ease;
	padding: 0.4rem 0.7rem;
	border-radius: 6px;
	font-size: 0.8rem;
	letter-spacing: 0.15em;
	text-transform: uppercase;
  }

  .header-nav a:hover {
	background: rgba(83, 213, 253, 0.15);
	color: #b6eeff;
	box-shadow: 0 0 12px rgba(83, 213, 253, 0.35);
	transform: translateY(-2px);
	padding: 0.75rem 1.25rem;
	border-radius: 8px;
  }

  .header-nav a.leader-link:hover {
	background: rgba(83, 213, 253, 0.15);
	transform: translateY(-2px);
	border-radius: 8px;
	color: white;
  }

  .header-nav a.loser-link:hover {
	background: rgba(213, 173, 77, 0.15);
	transform: translateY(-2px);
	border-radius: 8px;
	color: white;
  }

  .brand-subtitle {
    margin: 0;
    color: #d5ad4d;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .hero-eyebrow {
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    color: #d5ad4d;
  }

  .hero-copy {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #e5e7eb;
  }

  .game-placeholder-card {
    padding: 1.25rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

	.status-banner {
	display: flex;
	align-items: center;
	gap: 0.5rem;

	padding: 0.5rem 0.85rem;

	background: rgba(83, 213, 253, 0.12);
	border: 1px solid rgba(83, 213, 253, 0.35);
	border-radius: 12px;
	box-shadow: 0 0 18px rgba(83, 213, 253, 0.12);
	max-width: 420px;
  }

	.status-dot {
	width: 8px;
	height: 8px;

	background: #53d5fd;
	border-radius: 50%;
	box-shadow: 0 0 8px rgba(83, 213, 253, 0.7);
  }

  .dashboard-card {
	backdrop-filter: blur(8px);
    margin: 2rem auto;
    padding: 1.5rem;
    background: #061318;
    border-radius: 24px;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    max-width: 960px;
  }

  .dashboard-card h1 {
    margin: 0 0 1rem;
  }

  .leader-section .dashboard-card {
	background: #061318;
	border: 1px solid #53d5fd;
	box-shadow: 0 0 20px rgba(83,213,253,.15);
  }

  .loser-section .dashboard-card {
    background: #111;
	border: 1px solid #d5ad4d;
  }

  .leader-section table th,
  .leader-section table thead th {
    background: rgba(83, 213, 253, 0.08) !important;
	border-bottom: 1px solid rgba(83, 213, 253, 0.12);
    color: #53d5fd !important;
  }

  .loser-section table th,
  .loser-section table thead th {
    background: #432d00 !important;
    color: #d5ad4d !important;
	border-bottom: 1px solid rgba(213, 173, 77, 0.12);
  }

  /*table styles*/
  table {
	width: 100%;
	max-width: 900px;
	margin: 2rem auto;
	border-collapse: collapse;
	background: #061318;
	color: #b6eeff;
	border-radius: 16px;
	overflow: hidden;
	margin: 2rem auto;
  }

	th,
	td {
	padding: 1rem 1.25rem;
	text-align:center;
	border-bottom: 1px solid rgba(83, 213, 253, 0.12);
  }

	th {
	background: #222;
	color: white;
	font-weight: 700;
  }

  .table-label {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	white-space: nowrap;
  }

  .table-icon-bg {
	width: 36px;
	height: 36px;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	background: rgba(83, 213, 253, 0.12);
	border: 1px solid #53d5fd;
	border-radius: 50%;
	overflow: hidden;
	box-shadow: 0 0 0 1px rgba(83,213,253,0.25);
  }

  .table-icon {
	width: 100%;
	height: 100%;
	display: block;
	object-fit: cover;
  }

  .leader-first,
  .leader-second,
  .leader-third {
    background: transparent;
    color: inherit;
    box-shadow: none;
  }

  .leader-first td:first-child::before {
    content: '🏆';
    margin-right: 0.35rem;
  }
  .leader-second td:first-child::before {
    content: '🥈';
    margin-right: 0.35rem;
  }
  .leader-third td:first-child::before {
    content: '🥉';
    margin-right: 0.35rem;
  }
  .leader-first td:first-child,
  .leader-second td:first-child,
  .leader-third td:first-child {
    font-weight: 700;
    position: relative;
  }

  .leader-first td:first-child {
    overflow: visible;
  }

  .leader-first td:first-child::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0;
    height: 0;
    opacity: 0;
