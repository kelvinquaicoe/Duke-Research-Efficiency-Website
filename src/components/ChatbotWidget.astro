---
const configuredChatbotUrl = (import.meta.env.PUBLIC_CHATBOT_URL || '').trim();
---

<button
  id="chatbot-toggle"
  title="Chat with Slurm-O"
  aria-label="Open chatbot"
  data-chatbot-url={configuredChatbotUrl}
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
  </svg>
</button>

<div id="chatbot-modal" hidden>
  <div id="chatbot-header">
    <h3>Slurm<span>-O</span> AI</h3>
    <button id="chatbot-close" aria-label="Close chatbot">x</button>
  </div>
  <iframe id="chatbot-frame" src="about:blank" title="Slurm-O Chatbot"></iframe>
</div>

<div id="chatbot-confirm" hidden>
  <div id="chatbot-confirm-card">
    <h3>Close Chatbot?</h3>
    <p>Are you sure you want to close?</p>
    <div class="actions">
      <button id="chatbot-confirm-close">Close</button>
      <button id="chatbot-confirm-cancel">Cancel</button>
    </div>
  </div>
</div>

<script is:inline>
  const toggleBtn = document.getElementById('chatbot-toggle');
  const modal = document.getElementById('chatbot-modal');
  const frame = document.getElementById('chatbot-frame');
  const closeBtn = document.getElementById('chatbot-close');
  const confirm = document.getElementById('chatbot-confirm');
  const confirmCloseBtn = document.getElementById('chatbot-confirm-close');
  const confirmCancelBtn = document.getElementById('chatbot-confirm-cancel');

  const getDefaultChatbotUrl = () => {
    const { origin } = window.location;
    return `${origin}/chatbot/`;
  };

  const chatbotUrl = toggleBtn?.dataset?.chatbotUrl || getDefaultChatbotUrl();
  frame.src = chatbotUrl;

  const openModal = () => {
    modal.hidden = false;
    confirm.hidden = true;
  };

  const closeModal = () => {
    modal.hidden = true;
    confirm.hidden = true;
  };

  toggleBtn?.addEventListener('click', () => {
    if (modal.hidden) {
      openModal();
    } else {
      closeModal();
    }
  });

  closeBtn?.addEventListener('click', () => {
    confirm.hidden = false;
  });

  confirmCloseBtn?.addEventListener('click', closeModal);
  confirmCancelBtn?.addEventListener('click', () => {
    confirm.hidden = true;
  });

  confirm?.addEventListener('click', (event) => {
    if (event.target === confirm) {
      confirm.hidden = true;
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    if (!confirm.hidden) {
      confirm.hidden = true;
      return;
    }
    if (!modal.hidden) {
      closeModal();
    }
  });

  // Resize handle behavior for the bottom-right corner.
  const handle = document.createElement('div');
  handle.id = 'chatbot-resize-handle';
  modal.appendChild(handle);

  let isResizing = false;
  let startX = 0;
  let startY = 0;
  let startWidth = 400;
  let startHeight = 600;

  handle.addEventListener('mousedown', (event) => {
    if (event.button !== 0) return;
    isResizing = true;
    startX = event.clientX;
    startY = event.clientY;
    startWidth = modal.offsetWidth;
    startHeight = modal.offsetHeight;
    event.preventDefault();
  });

  document.addEventListener('mousemove', (event) => {
    if (!isResizing) return;
    const width = Math.max(300, startWidth + (event.clientX - startX));
    const height = Math.max(400, startHeight + (event.clientY - startY));
    modal.style.width = `${width}px`;
    modal.style.height = `${height}px`;
  });

  document.addEventListener('mouseup', () => {
    isResizing = false;
  });
</script>

<style>
  #chatbot-toggle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00c7ff 0%, #0096b4 100%);
    border: 2px solid rgba(255, 255, 255, 0.2);
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0, 199, 255, 0.4);
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  #chatbot-toggle:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 28px rgba(0, 199, 255, 0.5);
  }

  #chatbot-modal {
    position: fixed;
    bottom: 80px;
    right: 24px;
    width: 400px;
    height: 600px;
    background: #050810;
    border-radius: 12px;
    border: 2px solid rgba(0, 199, 255, 0.3);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8), 0 0 40px rgba(0, 199, 255, 0.2);
    z-index: 1001;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  #chatbot-modal[hidden],
  #chatbot-confirm[hidden] {
    display: none !important;
  }

  #chatbot-header {
    background: linear-gradient(135deg, rgba(0, 199, 255, 0.1) 0%, rgba(0, 150, 180, 0.05) 100%);
    border-bottom: 1px solid rgba(0, 199, 255, 0.2);
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #chatbot-header h3 {
    margin: 0;
    font-family: "Orbitron", sans-serif;
    color: #e2e8f8;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  #chatbot-header h3 span {
    color: #00c7ff;
  }

  #chatbot-close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 24px;
    cursor: pointer;
    width: 32px;
    height: 32px;
    line-height: 1;
  }

  #chatbot-close:hover {
    color: #ff4b4b;
  }

  #chatbot-frame {
    flex: 1;
    border: none;
  }

  #chatbot-confirm {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1002;
  }

  #chatbot-confirm-card {
    background: #0d1830;
    border: 2px solid rgba(0, 199, 255, 0.3);
    border-radius: 12px;
    padding: 24px;
    max-width: 300px;
    text-align: center;
  }

  #chatbot-confirm-card h3 {
    margin: 0 0 12px;
    color: #e2e8f8;
    font-size: 16px;
  }

  #chatbot-confirm-card p {
    margin: 0 0 20px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
  }

  #chatbot-confirm-card .actions {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  #chatbot-confirm-close {
    padding: 8px 20px;
    background: #ff4b4b;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
  }

  #chatbot-confirm-cancel {
    padding: 8px 20px;
    background: rgba(0, 199, 255, 0.2);
    color: #00c7ff;
    border: 1px solid rgba(0, 199, 255, 0.3);
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
  }

  #chatbot-resize-handle {
    width: 20px;
    height: 20px;
    position: absolute;
    bottom: 0;
    right: 0;
    cursor: nwse-resize;
    background: linear-gradient(135deg, transparent 0%, rgba(0, 199, 255, 0.3) 100%);
    border-radius: 0 0 10px 0;
  }

  @media (max-width: 768px) {
    #chatbot-modal {
      right: 12px;
      left: 12px;
      width: auto;
      height: min(70vh, 560px);
      bottom: 76px;
    }
  }
</style>