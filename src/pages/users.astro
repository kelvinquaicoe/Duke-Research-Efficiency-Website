---
import Layout from '../layouts/Layout.astro';
import UsersTable from '../components/UsersTable.jsx';
---

<Layout>
  <header class="users-header">
    <div class="header-brand">
      <img class="logo" src="/Lboard_Logo.png" alt="LBoard Logo" />
      <div class="brand-text">
        <h1>Cluzster Command</h1>
        <p class="brand-subtitle">Optimize jobs. Save GPU hours. Move the snail.</p>
      </div>
    </div>
    <nav class="header-nav">
      <a href="/">Game</a>
      <a class="leader-link" href="/#leader-section">Leader Board</a>
      <a class="loser-link" href="/#loser-section">Loser Board</a>
      <a href="/users">Users</a>
    </nav>
  </header>

  <main class="users-main">
    <section class="users-section">
      <div class="section-header">
        <h2>All Users</h2>
        <p class="section-description">Search and filter all users by efficiency, GPU hours, and more.</p>
      </div>
      <UsersTable client:load />
    </section>
  </main>
</Layout>

<style>
  .users-header {
    display: grid;
    grid-template-columns: 1fr;
    row-gap: 0.8rem;
    align-items: center;
    padding: 0.5rem 1rem;
    color: #fff;
    background: rgba(34, 34, 34, 0.96);
    min-height: 64px;
    backdrop-filter: blur(10px);
    box-sizing: border-box;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-self: start;
  }

  .header-brand h1 {
    margin: 0;
    font-family: 'Orbitron', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #53d5fd;
    text-shadow:
      0 0 8px #53d5fd,
      0 0 20px #53d5fd,
      0 0 40px rgba(83,213,253,.5);
    text-transform: uppercase;
  }

  .logo {
    width: 60px;
    height: 60px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .brand-subtitle {
    margin: 0;
    color: #a7f3d0;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .header-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3.5rem;
    justify-self: center;
  }

  .header-nav a {
    display: inline-block;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: white;
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 0.4rem 0.7rem;
    border-radius: 6px;
  }

  .header-nav a:hover {
    background: #717171;
    transform: translateY(-2px);
  }

  .header-nav .leader-link {
    color: white;
  }

  .header-nav .leader-link:hover {
    background: rgba(22, 163, 74, 0.2);
    color: white;
  }

  .header-nav .loser-link {
    color: white;
  }

  .header-nav .loser-link:hover {
    background: rgba(220, 38, 38, 0.2);
    color: white;
  }

  .users-main {
    margin: 0;
    min-height: 100vh;
    background: #f4f4f4;
  }

  .users-section {
    padding: 3rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .section-header h2 {
    margin: 0 0 0.5rem;
    font-size: 2rem;
    color: #222;
  }

  .section-description {
    margin: 0;
    color: #666;
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .header-nav {
      gap: 1.5rem;
    }

    .section-header h2 {
      font-size: 1.5rem;
    }
  }
</style>
